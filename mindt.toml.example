# =============================================================================
# MIND 测试配置文件模板
# 复制此文件为 mindt.toml 并填入实际 API Key：  cp mindt.toml.example mindt.toml
# 注意：mindt.toml 包含密钥，请勿提交到版本控制
# =============================================================================

# ---------------------------------------------------------------------------
# LLM 配置
# ---------------------------------------------------------------------------
[llm]
provider    = "openai"
temperature = 0.0

[llm.openai]
protocols    = "openai"
api_key      = ""                # 填入你的 OpenAI API Key
base_url     = "https://api.openai.com"
sdk_base     = "/v1"
llm_suffix   = "/chat/completions"
embed_suffix = "/embeddings"
model        = "gpt-4o-mini"

[llm.anthropic]
protocols    = "anthropic"
api_key      = ""                # 填入你的 Anthropic API Key
base_url     = "https://api.anthropic.com"
sdk_base     = ""
llm_suffix   = "/v1/messages"
embed_suffix = ""
model        = "claude-sonnet-4-20250514"

[llm.google]
protocols    = "google"
api_key      = ""                # 填入你的 Google API Key
base_url     = "https://generativelanguage.googleapis.com"
sdk_base     = ""
llm_suffix   = "/v1beta/models/{model}:generateContent"
embed_suffix = ""
model        = "gemini-2.0-flash"

# 示例：通过 template 继承添加第三方 provider
# [llm.deepseek]
# template = "llm.openai"
# api_key  = ""
# base_url = "https://api.deepseek.com"
# model    = "deepseek-chat"

# ---------------------------------------------------------------------------
# Embedding 配置
# ---------------------------------------------------------------------------
[embedding]
protocols    = "openai-embedding"
model        = "text-embedding-3-small"
api_key      = ""                # 填入 Embedding 服务的 API Key
base_url     = "https://api.openai.com"
sdk_base     = "/v1"
embed_suffix = "/embeddings"
dimensions   = 1536

# ---------------------------------------------------------------------------
# 向量存储配置（测试环境）
# ---------------------------------------------------------------------------
[vector_store]
provider        = "qdrant"
collection_name = "mind_test_memories"   # 测试用独立集合名
url             = ""
api_key         = ""
on_disk         = false

# ---------------------------------------------------------------------------
# 历史记录存储配置（测试环境）
# ---------------------------------------------------------------------------
[history_store]
db_path = "mind_test_history.db"         # 测试用独立数据库文件

# ---------------------------------------------------------------------------
# 日志配置
# ---------------------------------------------------------------------------
[logging]
level   = "INFO"               # DEBUG / INFO / WARNING / ERROR
console = true                 # 是否输出到控制台（stderr）
file    = ""                   # 日志文件路径，留空 = 不写文件，如 "mind.log"
format  = "%(asctime)s [%(levelname)s] %(name)s — %(message)s"

# ---------------------------------------------------------------------------
# 检索参数
# ---------------------------------------------------------------------------
[retrieval]
search_top_k     = 5
similarity_top_k = 5
