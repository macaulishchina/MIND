{
  "name": "owner_centered_relationship_cases",
  "focus": "owner-centered relationship projection",
  "description": "Relationship-focused owner-centered cases covering direct and inverse phrasing, stable named third parties, and projected memories derived from STL-backed state.",
  "cases": [
    {
      "id": "owner-rel-stable-001",
      "description": "named friend relation should project stable relation and occupation memories",
      "owner": {
        "external_user_id": "owner_rel_stable_001"
      },
      "turns": [
        {
          "messages": [
            {
              "role": "user",
              "content": "My friend Green is a football player"
            }
          ]
        }
      ],
      "expected_active_count": 2,
      "expected_active_memories": [
        {
          "canonical_text": "[friend:green] relation_to_owner=friend",
          "subject_ref": "friend:green",
          "field_key": "relation_to_owner",
          "fact_family": "relation"
        },
        {
          "canonical_text": "[friend:green] occupation=football player",
          "subject_ref": "friend:green",
          "field_key": "occupation",
          "fact_family": "attribute"
        }
      ],
      "expected_refs": [
        {
          "scope": "local",
          "ref_type": "person",
          "key": "green"
        }
      ],
      "expected_statements": [
        {
          "predicate": "friend",
          "args": [
            "@self",
            "@local/person(\"green\")"
          ]
        },
        {
          "predicate": "occupation",
          "args": [
            "@local/person(\"green\")",
            "football player"
          ]
        }
      ]
    },
    {
      "id": "owner-rel-owner-002",
