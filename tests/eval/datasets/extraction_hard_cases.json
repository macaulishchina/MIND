{
  "name": "extraction_hard_cases",
  "focus": "difficulty-hard mixed",
  "description": "Hard cases targeting relevance filtering, mixed stable-and-ephemeral content, and future-or-quoted content boundaries.",
  "cases": [
    {
      "id": "hard-001",
      "description": "中文过程性报错噪声应过滤",
      "input": "User: 我重试了三次命令，还是报 timeout。\nAssistant: 先重启服务看看。",
      "expected_facts": [],
      "should_not_extract": [
        "timeout",
        "重试",
        "重启服务"
      ],
      "expected_count_range": [
        0,
        0
      ],
      "difficulty": "hard"
    },
    {
      "id": "hard-002",
      "description": "temporary debugging log should be filtered",
      "input": "User: I checked the error log, retried the command, and still hit a timeout.\nAssistant: Restart the process and try again.",
      "expected_facts": [],
      "should_not_extract": [
        "error log",
        "timeout",
        "Restart the process"
      ],
      "expected_count_range": [
        0,
        0
      ],
      "difficulty": "hard"
    },
    {
      "id": "hard-003",
      "description": "assistant-only helpful suggestion should never be stored",
      "input": "User: Thanks.\nAssistant: You should try using bullet points and shorter messages.",
      "expected_facts": [],
      "should_not_extract": [
        "bullet points",
        "shorter messages"
      ],
      "expected_count_range": [
        0,
        0
      ],
      "difficulty": "hard"
    },
    {
      "id": "hard-004",
      "description": "phatic continuation request should not create memories",
      "input": "User: Hello, can you continue?\nAssistant: Sure.",
      "expected_facts": [],
      "should_not_extract": [
        "Hello",
        "continue",
        "Sure"
      ],
      "expected_count_range": [
        0,
        0
      ],
      "difficulty": "hard"
    },
    {
      "id": "hard-005",
      "description": "future relocation plan framed as hypothetical should be excluded",
      "input": "User: If I switch jobs next year, I might move to Berlin.\nAssistant: That could be fun.",
      "expected_facts": [],
      "should_not_extract": [
        "Berlin",
        "switch jobs"
      ],
      "expected_count_range": [
        0,
        0
      ],
      "difficulty": "hard"
    },
    {
      "id": "hard-006",
      "description": "stable preference mixed with transient issue should keep only the stable part",
      "input": "User: I use zsh every day, but today's deploy command timed out twice.\nAssistant: Let's inspect the logs.",
      "expected_facts": [
        {
          "match_any": [
            "zsh",
            "use zsh every day"
          ],
          "confidence_range": [
            0.8,
            1.0
          ]
        }
      ],
      "should_not_extract": [
        "timed out",
        "deploy command",
        "inspect the logs"
      ],
      "expected_count_range": [
        1,
        2
      ],
      "difficulty": "hard"
    },
    {
      "id": "hard-007",
      "description": "中文稳定习惯与临时排障混合时只保留稳定信息",
      "input": "User: 我平时用Vim，今天部署命令重试两次还是超时。\nAssistant: 先看日志。",
      "expected_facts": [
        {
          "match_any": [
            "Vim",
            "平时用Vim"
          ],
          "confidence_range": [
            0.8,
            1.0
          ]
        }
      ],
      "should_not_extract": [
        "部署命令",
        "重试",
        "超时",
        "看日志"
      ],
      "expected_count_range": [
        1,
        2
      ],
      "difficulty": "hard"
    },
    {
      "id": "hard-008",
      "description": "quoted external suggestion should not override user's own stable stack",
      "input": "User: My manager wants me to write more Rust, but I mostly write Python.\nAssistant: Understood.",
      "expected_facts": [
        {
          "match_any": [
            "mostly write Python",
            "Python"
          ],
          "confidence_range": [
            0.8,
            1.0
          ]
        }
      ],
      "should_not_extract": [
        "manager wants",
        "Rust"
      ],
      "expected_count_range": [
        1,
        2
      ],
      "difficulty": "hard"
    },
    {
      "id": "hard-009",
      "description": "quoted social pressure should not replace current preference",
      "input": "User: 我朋友总说我该喝拿铁，但我现在只喝美式。\nAssistant: 了解。",
      "expected_facts": [
        {
          "match_any": [
            "只喝美式",
            "美式",
            "americanos",
            "Americano",
            "only drinks Americano now"
          ],
          "confidence_range": [
            0.8,
            1.0
          ]
        }
      ],
      "should_not_extract": [
        "朋友总说",
        "拿铁"
      ],
      "expected_count_range": [
        1,
        2
      ],
      "difficulty": "hard"
    },
    {
      "id": "hard-010",
      "description": "current fact plus hypothetical future should keep only the current state",
      "input": "User: I live in Hangzhou now; if I move next year, maybe Singapore.\nAssistant: Got it.",
      "expected_facts": [
        {
          "match_any": [
            "Hangzhou",
            "live in Hangzhou now"
          ],
          "confidence_range": [
            0.8,
            1.0
          ]
        }
      ],
      "should_not_extract": [
        "Singapore"
      ],
      "expected_count_range": [
        1,
        2
      ],
      "difficulty": "hard"
    },
    {
      "id": "hard-011",
      "description": "中文当前事实加假设未来时只保留当前状态",
      "input": "User: 我现在住在杭州，如果明年搬家，可能去新加坡。\nAssistant: 收到。",
      "expected_facts": [
        {
          "match_any": [
            "杭州",
            "现在住在杭州",
            "Hangzhou",
            "currently lives in Hangzhou"
          ],
          "confidence_range": [
            0.8,
            1.0
          ]
        }
      ],
      "should_not_extract": [
        "新加坡"
      ],
      "expected_count_range": [
        1,
        2
      ],
      "difficulty": "hard"
    },
    {
      "id": "hard-012",
      "description": "committed future plan should still be extractable as user-relevant memory",
      "input": "User: I'm moving to Berlin next month and already signed the lease.\nAssistant: Exciting.",
      "expected_facts": [
        {
          "match_any": [
            "moving to Berlin next month",
            "Berlin",
            "signed the lease"
          ],
          "confidence_range": [
            0.6,
            1.0
          ]
        }
      ],
      "should_not_extract": [
        "Exciting"
      ],
      "expected_count_range": [
        1,
        2
      ],
      "difficulty": "hard"
    },
    {
      "id": "hard-013",
      "description": "mixed-language response preference should keep both language and format preference",
      "input": "User: 我一般用中文，但 summaries please in English.\nAssistant: 好的。",
      "expected_facts": [
        {
          "match_any": [
            "一般用中文",
            "usually uses Chinese",
            "中文",
            "generally uses Chinese",
            "User usually uses Chinese"
          ],
          "confidence_range": [
            0.8,
            1.0
          ]
        },
        {
          "match_any": [
            "summaries please in English",
            "summaries in English",
            "English summaries",
            "prefers summaries in English",
            "User prefers summaries in English",
            "provided in English",
            "summaries to be provided in English"
          ],
          "confidence_range": [
            0.8,
            1.0
          ]
        }
      ],
      "should_not_extract": [
        "好的"
      ],
      "expected_count_range": [
        2,
        3
      ],
      "difficulty": "hard"
    }
  ]
}