{
  "name": "extraction_medium_cases",
  "focus": "difficulty-medium mixed",
  "description": "Moderate-ambiguity cases with temporal reasoning, preference carryover, and multi-turn consolidation.",
  "cases": [
    {
      "id": "medium-001",
      "description": "中文工作经历时态切换",
      "input": "User: 我之前在网易做后端，现在在字节做AI。\nAssistant: 明白。",
      "expected_facts": [
        {
          "match_any": [
            "之前在网易",
            "网易",
            "NetEase",
            "过去在网易"
          ],
          "confidence_range": [
            0.8,
            1.0
          ]
        },
        {
          "match_any": [
            "现在在字节",
            "字节",
            "字节跳动",
            "ByteDance"
          ],
          "confidence_range": [
            0.8,
            1.0
          ]
        }
      ],
      "should_not_extract": [
        "明白"
      ],
      "expected_count_range": [
        2,
        3
      ],
      "difficulty": "medium"
    },
    {
      "id": "medium-002",
      "description": "interaction preference across turns",
      "input": "User: Please keep your answers short.\nAssistant: Sure.\nUser: Bullet points are best for me.\nAssistant: Noted.",
      "expected_facts": [
        {
          "match_any": [
            "answers short",
            "short answers",
            "concise answers",
            "keep your answers short",
            "prefers concise answers"
          ],
          "confidence_range": [
            0.8,
            1.0
          ]
        },
        {
          "match_any": [
            "bullet points",
            "lists",
            "formatted as lists",
            "list-form responses",
            "prefers list-form responses"
          ],
          "confidence_range": [
            0.8,
            1.0
          ]
        }
      ],
      "should_not_extract": [
        "Sure",
        "Noted"
      ],
      "expected_count_range": [
        1,
        3
      ],
      "difficulty": "medium"
    },
    {
      "id": "medium-003",
      "description": "中文交互偏好多轮说明",
      "input": "User: 回答尽量简短。\nAssistant: 好的。\nUser: 最好用列表。\nAssistant: 收到。",
      "expected_facts": [
        {
          "match_any": [
