{
  "name": "extraction_temporal_cases",
  "focus": "temporal and state changes",
  "description": "Checks whether extraction preserves past-vs-present distinctions instead of collapsing them.",
  "cases": [
    {
      "id": "temporal-001",
      "description": "English past and current work state",
      "input": "User: I used to work at NetEase as a backend engineer, and now I work at ByteDance on AI.\nAssistant: Got it.",
      "expected_facts": [
        {"match_any": ["used to work at NetEase", "previously worked", "NetEase"], "confidence_range": [0.8, 1.0]},
        {"match_any": ["now I work at ByteDance", "now works at ByteDance", "ByteDance"], "confidence_range": [0.8, 1.0]}
      ],
      "should_not_extract": ["Got it"],
      "expected_count_range": [2, 3],
      "difficulty": "medium"
    },
    {
      "id": "temporal-002",
      "description": "中文时态切换应拆成两个事实",
      "input": "User: 我之前在网易做后端，现在在字节做AI。\nAssistant: 明白。",
      "expected_facts": [
        {"match_any": ["之前在网易", "previously worked", "NetEase"], "confidence_range": [0.8, 1.0]},
        {"match_any": ["现在在字节", "now works at ByteDance", "ByteDance"], "confidence_range": [0.8, 1.0]}
      ],
      "should_not_extract": ["明白"],
      "expected_count_range": [2, 3],
      "difficulty": "medium"
    },
    {
      "id": "temporal-003",
      "description": "preference evolution should preserve the updated state",
      "input": "User: I used to drink lattes, but now I only drink americanos.\nAssistant: Understood.",
      "expected_facts": [
        {"match_any": ["used to drink lattes", "lattes"], "confidence_range": [0.8, 1.0]},
        {"match_any": ["only drink americanos", "americanos", "now drinks americanos"], "confidence_range": [0.8, 1.0]}
      ],
      "should_not_extract": ["Understood"],
      "expected_count_range": [2, 3],
      "difficulty": "medium"
    },
    {
      "id": "temporal-004",
      "description": "past and current location should both survive",
      "input": "User: Last year I lived in London, and now I live in Singapore.\nAssistant: Noted.",
      "expected_facts": [
        {"match_any": ["lived in London", "London"], "confidence_range": [0.8, 1.0]},
        {"match_any": ["live in Singapore", "Singapore"], "confidence_range": [0.8, 1.0]}
      ],
      "should_not_extract": ["Noted"],
      "expected_count_range": [2, 3],
      "difficulty": "medium"
    },
    {
      "id": "temporal-005",
      "description": "role change should keep before and after states",
      "input": "User: I used to manage a team, but now I am an individual contributor.\nAssistant: Got it.",
      "expected_facts": [
        {"match_any": ["used to manage a team", "manage a team"], "confidence_range": [0.8, 1.0]},
        {"match_any": ["individual contributor", "now I am an individual contributor"], "confidence_range": [0.8, 1.0]}
      ],
      "should_not_extract": ["Got it"],
      "expected_count_range": [2, 3],
      "difficulty": "medium"
    },
    {
      "id": "temporal-006",
      "description": "中文习惯时段变化",
      "input": "User: 我以前早上跑步，现在晚上跑步。\nAssistant: 好的。",
      "expected_facts": [
        {"match_any": ["以前早上跑步", "morning", "早上跑步"], "confidence_range": [0.8, 1.0]},
        {"match_any": ["现在晚上跑步", "evening", "晚上跑步"], "confidence_range": [0.8, 1.0]}
      ],
      "should_not_extract": ["好的"],
      "expected_count_range": [2, 3],
      "difficulty": "medium"
    },
    {
      "id": "temporal-007",
      "description": "before and now hobby change",
      "input": "User: I used to learn piano, but now I practice violin every day.\nAssistant: Nice.",
      "expected_facts": [
        {"match_any": ["used to learn piano", "piano"], "confidence_range": [0.8, 1.0]},
        {"match_any": ["practice violin every day", "violin", "every day"], "confidence_range": [0.8, 1.0]}
      ],
      "should_not_extract": ["Nice"],
      "expected_count_range": [2, 3],
      "difficulty": "medium"
    },
    {
      "id": "temporal-008",
      "description": "目前状态与过去状态分离",
      "input": "User: 我之前住在北京，目前住在上海。\nAssistant: 了解。",
      "expected_facts": [
        {"match_any": ["之前住在北京", "previously lived in Beijing", "北京"], "confidence_range": [0.8, 1.0]},
        {"match_any": ["目前住在上海", "now lives in Shanghai", "上海"], "confidence_range": [0.8, 1.0]}
      ],
      "should_not_extract": ["了解"],
      "expected_count_range": [2, 3],
      "difficulty": "medium"
    },
    {
      "id": "temporal-009",
      "description": "diet change should keep old and new state",
      "input": "User: I used to be vegetarian, but now I eat fish again.\nAssistant: Understood.",
      "expected_facts": [
        {"match_any": ["used to be vegetarian", "vegetarian"], "confidence_range": [0.8, 1.0]},
        {"match_any": ["eat fish again", "fish", "now eats fish"], "confidence_range": [0.8, 1.0]}
      ],
      "should_not_extract": ["Understood"],
      "expected_count_range": [2, 3],
      "difficulty": "medium"
    },
    {
      "id": "temporal-010",
      "description": "中文工作地点变化",
      "input": "User: 我去年在杭州工作，现在在深圳。\nAssistant: 收到。",
      "expected_facts": [
        {"match_any": ["去年在杭州工作", "杭州", "worked in Hangzhou"], "confidence_range": [0.8, 1.0]},
        {"match_any": ["现在在深圳", "深圳", "now in Shenzhen"], "confidence_range": [0.8, 1.0]}
      ],
      "should_not_extract": ["收到"],
      "expected_count_range": [2, 3],
      "difficulty": "medium"
    }
  ]
}