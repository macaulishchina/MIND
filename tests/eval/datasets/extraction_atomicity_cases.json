{
  "name": "extraction_atomicity_cases",
  "focus": "atomic splitting",
  "description": "Checks whether one user turn is decomposed into the right number of fact-shaped items.",
  "cases": [
    {
      "id": "atomicity-001",
      "description": "English explicit profile bundle should split into separate facts",
      "input": "User: My name is Alice, I work at Stripe, and I drink black coffee every day.\nAssistant: Noted.",
      "expected_facts": [
        {"text_contains": "Alice", "confidence_range": [0.8, 1.0]},
        {"text_contains": "Stripe", "confidence_range": [0.8, 1.0]},
        {"text_contains": "black coffee", "confidence_range": [0.8, 1.0]}
      ],
      "should_not_extract": ["Noted"],
      "expected_count_range": [2, 4],
      "difficulty": "easy"
    },
    {
      "id": "atomicity-002",
      "description": "中文多事实显式陈述",
      "input": "User: 我叫张三，今年28岁，在网易工作，喜欢喝黑咖啡。\nAssistant: 记住了。",
      "expected_facts": [
        {"match_any": ["张三", "name is 张三"], "confidence_range": [0.8, 1.0]},
        {"match_any": ["28", "28 years old"], "confidence_range": [0.8, 1.0]},
        {"match_any": ["网易", "NetEase"], "confidence_range": [0.8, 1.0]},
        {"match_any": ["黑咖啡", "black coffee"], "confidence_range": [0.8, 1.0]}
      ],
      "should_not_extract": ["记住了"],
      "expected_count_range": [3, 5],
      "difficulty": "easy"
    },
    {
      "id": "atomicity-003",
      "description": "事件型内容可压缩但不应过度合并",
      "input": "User: 我上周开始学吉他，现在每天练一个小时。\nAssistant: 很棒。",
      "expected_facts": [
        {"match_any": ["学吉他", "learning guitar", "开始学习吉他"], "confidence_range": [0.6, 1.0]},
        {"match_any": ["每天练一个小时", "one hour", "an hour every day", "每天练习吉他一个小时"], "confidence_range": [0.6, 1.0]}
      ],
      "should_not_extract": ["很棒"],
      "expected_count_range": [1, 3],
      "difficulty": "medium"
    },
    {
      "id": "atomicity-004",
      "description": "semicolon-separated preferences should split cleanly",
      "input": "User: I like tea; I enjoy hiking; I use Vim at work.\nAssistant: Noted.",
      "expected_facts": [
        {"text_contains": "tea", "confidence_range": [0.8, 1.0]},
        {"text_contains": "hiking", "confidence_range": [0.8, 1.0]},
        {"text_contains": "Vim", "confidence_range": [0.8, 1.0]}
      ],
      "should_not_extract": ["Noted"],
      "expected_count_range": [3, 4],
      "difficulty": "easy"
    },
    {
      "id": "atomicity-005",
      "description": "family, location, and work should not collapse into one sentence",
      "input": "User: I live in Singapore, I manage a small team, and I have two cats.\nAssistant: Got it.",
      "expected_facts": [
        {"text_contains": "Singapore", "confidence_range": [0.8, 1.0]},
        {"match_any": ["manage a small team", "small team"], "confidence_range": [0.8, 1.0]},
        {"match_any": ["two cats", "cats"], "confidence_range": [0.8, 1.0]}
      ],
      "should_not_extract": ["Got it"],
      "expected_count_range": [3, 4],
      "difficulty": "easy"
    },
    {
      "id": "atomicity-006",
      "description": "健康限制和日常习惯应拆开",
      "input": "User: 我乳糖不耐受，早上只喝美式咖啡。\nAssistant: 明白。",
      "expected_facts": [
        {"match_any": ["乳糖不耐受", "lactose intolerant"], "confidence_range": [0.8, 1.0]},
        {"match_any": ["早上只喝美式咖啡", "americano", "美式咖啡"], "confidence_range": [0.8, 1.0]}
      ],
      "should_not_extract": ["明白"],
      "expected_count_range": [2, 3],
      "difficulty": "medium"
    },
    {
      "id": "atomicity-007",
      "description": "work stack bundle should split into role and tools",
      "input": "User: I am a backend engineer, I write Python every day, and I deploy to Kubernetes.\nAssistant: Sounds good.",
      "expected_facts": [
        {"match_any": ["backend engineer", "engineer"], "confidence_range": [0.8, 1.0]},
        {"text_contains": "Python", "confidence_range": [0.8, 1.0]},
        {"text_contains": "Kubernetes", "confidence_range": [0.8, 1.0]}
      ],
      "should_not_extract": ["Sounds good"],
      "expected_count_range": [3, 4],
      "difficulty": "easy"
    },
    {
      "id": "atomicity-008",
      "description": "中文偏好列表应拆分而不是压成一句",
      "input": "User: 我喜欢乌龙茶；我喜欢登山；我喜欢摄影。\nAssistant: 好的。",
      "expected_facts": [
        {"match_any": ["乌龙茶", "oolong tea"], "confidence_range": [0.8, 1.0]},
        {"match_any": ["登山", "hiking"], "confidence_range": [0.8, 1.0]},
        {"match_any": ["摄影", "photography"], "confidence_range": [0.8, 1.0]}
      ],
      "should_not_extract": ["好的"],
      "expected_count_range": [3, 4],
      "difficulty": "medium"
    },
    {
      "id": "atomicity-009",
      "description": "mixed event and stable preference should split",
      "input": "User: I started running last month, and I always run before breakfast.\nAssistant: Nice.",
      "expected_facts": [
        {"match_any": ["started running last month", "running last month"], "confidence_range": [0.6, 1.0]},
        {"match_any": ["before breakfast", "always run before breakfast"], "confidence_range": [0.8, 1.0]}
      ],
      "should_not_extract": ["Nice"],
      "expected_count_range": [2, 3],
      "difficulty": "medium"
    },
    {
      "id": "atomicity-010",
      "description": "目前状态与习惯应拆开",
      "input": "User: 目前我在上海工作，晚上固定去健身房。\nAssistant: 收到。",
      "expected_facts": [
        {"match_any": ["在上海工作", "works in Shanghai", "上海"], "confidence_range": [0.8, 1.0]},
        {"match_any": ["晚上固定去健身房", "gym", "健身房"], "confidence_range": [0.8, 1.0]}
      ],
      "should_not_extract": ["收到"],
      "expected_count_range": [2, 3],
      "difficulty": "medium"
    }
  ]
}