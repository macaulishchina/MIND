{
  "id": "owner-rel-split-001",
  "suite": "relationship",
  "description": "mother location case should project relation and location separately",
  "owner": {
    "external_user_id": "owner_rel_split_001"
  },
  "turns": [
    {
      "messages": [
        {
          "role": "user",
          "content": "My mother Lisa lives in Toronto"
        }
      ]
    }
  ],
  "stages": {
    "owner_add": {
      "expected_active_count": 2,
      "expected_active_memories": [
        {
          "canonical_text": "[mother:lisa] relation_to_owner=mother",
          "subject_ref": "mother:lisa",
          "field_key": "relation_to_owner",
          "fact_family": "relation"
        },
        {
          "canonical_text": "[mother:lisa] location=Toronto",
          "subject_ref": "mother:lisa",
          "field_key": "location",
          "fact_family": "attribute"
        }
      ]
    },
    "stl_extract": {
      "expected_stl": "@l: person \"lisa\"\n@t: city \"toronto\"\n$p1 = mother(@s, @l)\n$p2 = live_in(@l, @t)",
      "expected_refs": [
        {
          "scope": "named",
          "ref_type": "person",
          "key": "lisa"
        },
        {
          "scope": "named",
          "ref_type": "city",
          "key": "toronto"
        }
      ],
      "expected_statements": [
        {
          "predicate": "mother",
          "args": [
            "@self",
            "@person(\"lisa\")"
          ]
        },
        {
          "predicate": "live_in",
          "args_contains": [
            "lisa",
            "toronto"
          ]
        }
      ]
    }
  }
}
