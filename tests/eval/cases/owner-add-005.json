{
  "id": "owner-add-005",
  "suite": "add",
  "description": "single-value fields keep only the chunk-final value when one submitted chunk contains a correction",
  "owner": {
    "external_user_id": "eval_update_001"
  },
  "turns": [
    {
      "messages": [
        {
          "role": "user",
          "content": "My name is Dave"
        }
      ]
    },
    {
      "messages": [
        {
          "role": "user",
          "content": "My name is David"
        }
      ]
    }
  ],
  "stages": {
    "owner_add": {
      "expected_active_count": 1,
      "expected_active_memories": [
        {
          "canonical_text": "[self] name=David",
          "subject_ref": "self",
          "field_key": "name",
          "fact_family": "attribute"
        }
      ]
    },
    "stl_extract": {
      "expected_stl": "$p1 = name(@s, \"Dave\")\n$p2 = name(@s, \"David\")\n$f1 = correct_intent(@s, $p2)\nnote($f1, \"CORRECTION: name changed from Dave to David\")",
      "expected_statements": [
        {
          "predicate": "name",
          "args": [
            "@self",
            "David"
          ]
        }
      ]
    }
  }
}
