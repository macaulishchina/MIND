{
  "id": "owner-comprehensive-001",
  "suite": "comprehensive",
  "description": "多轮中文对话：涵盖关系、框架、事件、限定词、纠正、多值属性、不同置信度",
  "owner": {
    "external_user_id": "eval_comprehensive_001"
  },
