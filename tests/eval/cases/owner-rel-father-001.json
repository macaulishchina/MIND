{
  "id": "owner-rel-father-001",
  "suite": "relationship",
  "description": "father location case should keep relation and location memories",
  "owner": {
    "external_user_id": "owner_rel_father_001"
  },
  "turns": [
    {
      "messages": [
        {
          "role": "user",
          "content": "My father Owen lives in Dublin"
        }
      ]
    }
  ],
  "stages": {
    "owner_add": {
      "expected_active_count": 2,
      "expected_active_memories": [
        {
          "canonical_text": "[father:owen] relation_to_owner=father",
          "subject_ref": "father:owen",
          "field_key": "relation_to_owner",
          "fact_family": "relation"
        },
        {
          "canonical_text": "[father:owen] location=Dublin",
          "subject_ref": "father:owen",
          "field_key": "location",
          "fact_family": "attribute"
        }
      ]
    },
    "stl_extract": {
      "expected_stl": "@o: person \"owen\"\n@d: city \"dublin\"\n$p1 = father(@s, @o)\n$p2 = live_in(@o, @d)",
      "expected_refs": [
        {
          "scope": "named",
          "ref_type": "person",
          "key": "owen"
        },
        {
          "scope": "named",
          "ref_type": "city",
          "key": "dublin"
        }
      ],
      "expected_statements": [
        {
          "predicate": "father",
          "args": [
            "@self",
            "@person(\"owen\")"
          ]
        },
        {
          "predicate": "live_in",
          "args_contains": [
            "owen",
            "dublin"
          ]
        }
      ]
    }
  }
}
