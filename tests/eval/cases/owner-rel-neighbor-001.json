{
  "id": "owner-rel-neighbor-001",
  "suite": "relationship",
  "description": "neighbor drink case should keep relation and projected drink memory",
  "owner": {
    "external_user_id": "owner_rel_neighbor_001"
  },
  "turns": [
    {
      "messages": [
        {
          "role": "user",
          "content": "My neighbor Alex drinks green tea"
        }
      ]
    }
  ],
  "stages": {
    "owner_add": {
      "expected_active_count": 2,
      "expected_active_memories": [
        {
          "canonical_text": "[neighbor:alex] relation_to_owner=neighbor",
          "subject_ref": "neighbor:alex",
          "field_key": "relation_to_owner",
          "fact_family": "relation"
        },
        {
          "canonical_text": "[neighbor:alex] habit:drink=green tea",
          "subject_ref": "neighbor:alex",
          "field_key": "habit:drink",
          "fact_family": "habit"
        }
      ]
    },
    "stl_extract": {
      "expected_stl": "@a: person \"alex\"\n$p1 = neighbor(@s, @a)\n$p2 = drink(@a, \"green tea\")",
      "expected_refs": [
        {
          "scope": "named",
          "ref_type": "person",
          "key": "alex"
        }
      ],
      "expected_statements": [
        {
          "predicate": "neighbor",
          "args": [
            "@self",
            "@person(\"alex\")"
          ]
        },
        {
          "predicate": "drink",
          "args": [
            "@person(\"alex\")",
            "green tea"
          ]
        }
      ]
    }
  }
}
