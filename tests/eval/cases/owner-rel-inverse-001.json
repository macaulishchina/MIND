{
  "id": "owner-rel-inverse-001",
  "suite": "relationship",
  "description": "inverse phrasing still keeps a stable friend subject",
  "owner": {
    "external_user_id": "owner_rel_inverse_001"
  },
  "turns": [
    {
      "messages": [
        {
          "role": "user",
          "content": "Green is my friend and he likes jazz"
        }
      ]
    }
  ],
  "stages": {
    "owner_add": {
      "expected_active_count": 2,
      "expected_active_memories": [
        {
          "canonical_text": "[friend:green] relation_to_owner=friend",
          "subject_ref": "friend:green",
          "field_key": "relation_to_owner",
          "fact_family": "relation"
        },
        {
          "canonical_text": "[friend:green] preference:like=jazz",
          "subject_ref": "friend:green",
          "field_key": "preference:like",
          "fact_family": "preference"
        }
      ]
    },
    "stl_extract": {
      "expected_stl": "@g: person \"green\"\n$p1 = friend(@s, @g)\n$p2 = like(@g, \"jazz\")",
      "expected_refs": [
        {
          "scope": "named",
          "ref_type": "person",
          "key": "green"
        }
      ],
      "expected_statements": [
        {
          "predicate": "friend",
          "args": [
            "@self",
            "@person(\"green\")"
          ]
        },
        {
          "predicate": "like",
          "args": [
            "@person(\"green\")",
            "jazz"
          ]
        }
      ]
    }
  }
}
