{
  "id": "owner-add-002",
  "suite": "add",
  "description": "anonymous owner is reused across one multi-turn submitted chunk",
  "owner": {
    "anonymous_session_id": "eval_anon_001"
  },
  "turns": [
    {
      "messages": [
        {
          "role": "user",
          "content": "My name is June"
        }
      ]
    },
    {
      "messages": [
        {
          "role": "user",
          "content": "I live in Hangzhou"
        }
      ]
    }
  ],
  "stages": {
    "owner_add": {
      "expected_active_count": 2,
      "expected_active_memories": [
        {
          "canonical_text": "[self] name=June",
          "subject_ref": "self",
          "field_key": "name",
          "fact_family": "attribute"
        },
        {
          "canonical_text": "[self] location=Hangzhou",
          "subject_ref": "self",
          "field_key": "location",
          "fact_family": "attribute"
        }
      ]
    },
    "stl_extract": {
      "expected_stl": "@h: city \"Hangzhou\"\n$p1 = name(@s, \"June\")\n$p2 = live_in(@s, @h)",
      "expected_statements": [
        {
          "predicate": "name",
          "args": [
            "@self",
            "June"
          ]
        },
        {
          "predicate": "live_in",
          "args_contains": [
            "@self",
            "Hangzhou"
          ]
        }
      ]
    }
  }
}
