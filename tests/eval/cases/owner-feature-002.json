{
  "id": "owner-feature-002",
  "suite": "feature",
  "description": "say frame keeps speaker and quoted proposition",
  "owner": {
    "external_user_id": "feature_say_001"
  },
  "turns": [
    {
      "messages": [
        {
          "role": "user",
          "content": "Mike says Tom lives in Tokyo"
        }
      ]
    }
  ],
  "stages": {
    "stl_extract": {
      "expected_stl": "@m: person \"mike\"\n@t: person \"tom\"\n@k: city \"tokyo\"\n$p1 = live_in(@t, @k)\n$f1 = say(@m, $p1)",
      "expected_refs": [
        {
          "scope": "named",
          "ref_type": "person",
          "key": "mike"
        },
        {
          "scope": "named",
          "ref_type": "person",
          "key": "tom"
        },
        {
          "scope": "named",
          "ref_type": "city",
          "key": "tokyo"
        }
      ],
      "expected_statements": [
        {
          "predicate": "live_in",
          "args": [
            "@person(\"tom\")",
            "@city(\"tokyo\")"
          ]
        },
        {
          "predicate": "say"
        }
      ]
    }
  }
}
