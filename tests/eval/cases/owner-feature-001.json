{
  "id": "owner-feature-001",
  "suite": "feature",
  "description": "hope frame preserves both proposition and frame",
  "owner": {
    "external_user_id": "feature_hope_001"
  },
  "turns": [
    {
      "messages": [
        {
          "role": "user",
          "content": "I hope Tom comes to Tokyo"
        }
      ]
    }
  ],
  "stages": {
    "stl_extract": {
      "expected_stl": "@t: person \"tom\"\n@k: city \"tokyo\"\n$p1 = come(@t, @k)\n$f1 = hope(@s, $p1)",
      "expected_refs": [
        {
          "scope": "named",
          "ref_type": "person",
          "key": "tom"
        },
        {
          "scope": "named",
          "ref_type": "city",
          "key": "tokyo"
        }
      ],
      "expected_statements": [
        {
          "predicate": "come",
          "args": [
            "@person(\"tom\")",
            "@city(\"tokyo\")"
          ]
        },
        {
          "predicate": "hope"
        }
      ]
    }
  }
}
