# =============================================================================
# MIND 配置文件模板
# 复制此文件为 mind.toml 并填入实际 API Key：  cp mind.toml.example mind.toml
# 注意：mind.toml 包含密钥，请勿提交到版本控制
# =============================================================================

[llm]
provider    = "leihuo"          # openai | anthropic | google | fake | other provider
temperature = 0.0
extraction_temperature = 0.0     # STL extraction 默认采样温度；留空或删除 = 跟随 temperature
timeout     = 120.0             # 普通在线请求超时（秒）
batch       = false              # true = 路由到 batch 端点（需 provider 配置 batch_base_url）
# batch_timeout = 3600.0        # batch 模式 SDK 超时（秒），默认 3600

# 维护中的在线 STL 抽取默认策略
[llm.stl_extraction]
provider = "leihuo"
model = "gpt-5.4-mini"
temperature = 0.0
timeout = 10.0

#[llm.decision]
#provider = "openai"
#model = "gpt-5.4-nano"

[llm.openai]
protocols    = "openai"
api_key      = ""                # 填入你的 OpenAI API Key
base_url     = "https://api.openai.com"
sdk_base     = "/v1"
llm_suffix   = "/chat/completions"
embed_suffix = "/embeddings"
model        = "gpt-5.4-nano"

[llm.anthropic]
protocols    = "anthropic"
api_key      = ""                # 填入你的 Anthropic API Key
base_url     = "https://api.anthropic.com"
sdk_base     = ""
llm_suffix   = "/v1/messages"
embed_suffix = ""
model        = "claude-haiku-4-5-20251001"

[llm.google]
protocols    = "google"
api_key      = ""                # 填入你的 Google API Key
base_url     = "https://generativelanguage.googleapis.com"
sdk_base     = ""
llm_suffix   = "/v1beta/models/{model}:generateContent"
embed_suffix = ""
model        = "gemini-3.1-flash-lite-preview"

[llm.fake]
protocols    = "fake"
api_key      = ""
base_url     = ""
sdk_base     = ""
llm_suffix   = ""
embed_suffix = ""
model        = "fake-memory-test"

# 示例：通过 template 继承添加第三方 provider
[llm.deepseek]
template     = "llm.openai"
api_key      = ""
base_url     = "https://api.deepseek.com"
model        = "deepseek-chat"

[llm.aliyun]
template     = "llm.openai"
api_key      = ""
base_url     = "https://dashscope.aliyuncs.com"
sdk_base     = "/compatible-mode/v1"
model        = "deepseek-v3.2"
batch_base_url = "https://batch.dashscope.aliyuncs.com"  # Aliyun Batch Chat 端点（50% 折扣）

[llm.leihuo]
template     = "llm.openai"
api_key      = ""
base_url     = "https://ai.leihuo.netease.com"
model        = "qwen3.5-flash"

[embedding]
protocols    = "openai-embedding"
model        = "text-embedding-v4"
api_key      = ""                # 填入 Embedding 服务的 API Key
base_url     = "https://dashscope.aliyuncs.com/compatible-mode"
sdk_base     = "/v1"
embed_suffix = "/embeddings"
dimensions   = 1024

# 若需使用本地 fake embedding，可切换为：
# protocols    = "fake-embedding"
# model        = "fake-memory-embedding"
# api_key      = ""
# base_url     = ""
# sdk_base     = "/v1"
# embed_suffix = "/embeddings"
# dimensions   = 128

[vector_store]
provider        = "pgvector"
collection_name = "mind_memories"
dsn             = "postgresql://postgres:postgres@localhost:5432/mind"
url             = ""                # qdrant provider 使用
api_key         = ""                # qdrant provider 使用
on_disk         = false             # qdrant provider 使用

# 若需继续使用 Qdrant，可切换为：
# provider        = "qdrant"
# collection_name = "mind_memories"
# url             = "http://localhost:6333"
# api_key         = ""
# on_disk         = false

[history_store]
provider   = "postgres"
db_path    = "mind_history.db"      # sqlite provider 使用
dsn        = "postgresql://postgres:postgres@localhost:5432/mind"
table_name = "memory_history"

[logging]
level   = "INFO"               # DEBUG / INFO / WARNING / ERROR
console = true                 # 是否输出到控制台（stderr）
file    = ""                   # 日志文件路径，留空 = 不写文件，如 "mind.log"
format  = "%(asctime)s [%(levelname)s] %(name)s — %(message)s"

# ── 操作日志开关 ──
ops_llm          = true        # LLM + Embedding 调用日志（🧠 / 🔗）
ops_vector_store = true        # 向量存储操作日志（📦）
ops_database     = true        # 数据库操作日志（💾）
verbose          = false       # 详细模式：显示每次操作的原始输入/输出（调试用）

[retrieval]
search_top_k     = 5           # search() 返回的最大结果数
similarity_top_k = 5           # add() 时去重搜索的 Top-K

[concurrency]
max_workers           = 20   # 写操作全局线程池大小
min_available_workers = 2    # 保底保留线程数，防止单次 add 饿死其他调用
                             # 单次 add 最大并行度 = max_workers - min_available_workers
                             # 设为 0 = 不保底；max_workers = 1 = 完全串行

# ---------------------------------------------------------------------------
# 提示词增强配置
# ---------------------------------------------------------------------------
[prompts]
stl_extraction_supplement = false  # 对 STL 提取阶段追加扩展提示词（更详细的实体/谓词/修正规则）
                                   # 在线默认保持关闭；如需高成本实验再显式开启
