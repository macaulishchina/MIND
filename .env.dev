# ============================================================
# .env.dev — 开发环境变量模板
# ============================================================
# 复制到 .env.dev.local 使用: cp .env.dev .env.dev.local
# 或使用一键脚本:            ./scripts/dev.sh (会自动复制)

# Required
MIND_POSTGRES_USER=postgres
MIND_POSTGRES_PASSWORD=postgres
MIND_POSTGRES_DB=mind
MIND_POSTGRES_DSN=postgresql+psycopg://postgres:postgres@postgres:5432/mind
MIND_API_KEY=dev-key

# Provider (开发默认使用 stub，无需真实 LLM)
MIND_PROVIDER=stub
MIND_MODEL=deterministic

# Dev settings (MIND 1860x 端口族: API 18600, 文档热更 18602)
MIND_API_BIND=0.0.0.0:18600
MIND_DOCS_BIND=0.0.0.0:18602
MIND_LOG_LEVEL=DEBUG
MIND_DEV_MODE=true

# Docker build acceleration (optional)
MIND_PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
MIND_PIP_EXTRA_INDEX_URL=
MIND_PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn
