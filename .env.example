# ============================================================
# .env.example — 环境变量模板 (环境无关)
# ============================================================
#
# 请勿直接使用此文件。根据用途选择对应模板:
#
#   开发环境: cp .env.dev .env.dev.local
#   生产环境: cp .env.prod .env.prod.local
#
# 下面列出所有可用的环境变量及说明。

# Required — 必须设置
MIND_POSTGRES_USER=postgres
MIND_POSTGRES_PASSWORD=change-me
MIND_POSTGRES_DB=mind
MIND_POSTGRES_DSN=postgresql+psycopg://postgres:change-me@postgres:5432/mind
MIND_API_KEY=change-me

# Provider — AI 提供者配置
MIND_PROVIDER=stub
MIND_MODEL=deterministic

# Optional
MIND_API_BIND=0.0.0.0:18600
MIND_DOCS_BIND=0.0.0.0:18601
MIND_LOG_LEVEL=INFO
MIND_DEV_MODE=false

# Docker build acceleration (optional; set to your internal/nearby PyPI mirror)
MIND_PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
MIND_PIP_EXTRA_INDEX_URL=
MIND_PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn
